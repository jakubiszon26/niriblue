#!/usr/bin/bash
# First-boot Homebrew install into /var/home/linuxbrew. Retries each boot until it
# succeeds (e.g. once the primary user exists).
set -uo pipefail

MARKER=/var/lib/niriblue/brew-setup.done

# Exit without the marker if there is no primary user yet, so it retries next boot.
USERNAME="$(getent passwd 1000 | cut -d: -f1)"
if [ -z "${USERNAME}" ]; then
    echo "brew-setup: no UID 1000 user yet, retrying next boot"
    exit 0
fi

# /home is a symlink to /var/home on bootc
mkdir -p /var/home/linuxbrew
chown "${USERNAME}:${USERNAME}" /var/home/linuxbrew

sudo -u "${USERNAME}" NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || true

if [ -x /var/home/linuxbrew/.linuxbrew/bin/brew ]; then
    mkdir -p "$(dirname "${MARKER}")"
    touch "${MARKER}"
else
    echo "brew-setup: install failed, retrying next boot"
fi
