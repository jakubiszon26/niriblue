#!/usr/bin/bash
# First-boot bootstrap of the sysexts-manager tool ONLY.
#
# niriblue ships NO sysexts by default: this just makes the `sysexts-manager` binary
# available and merged into /usr so the user can add whatever they want after install
# (`sysexts-manager add <name> <url> && sysexts-manager enable`). See LAYERING.md.
#
# sysexts-manager lives in /var/lib/extensions* -- machine-local state on bootc -- so it
# cannot be baked into the image and is fetched here at first boot instead, mirroring the
# flatpak/nix setup units (idempotent + retry until network is up and the sysext is merged).
set -uo pipefail

MARKER=/var/lib/niriblue/sysext-setup.done
SM_VERSION="0.3.3"        # sysexts-manager release (pinned)
VERSION_ID="44"           # Fedora major
ARCH="x86-64"             # systemd arch name

URL="https://github.com/travier/sysexts-manager/releases/download/sysexts-manager"
NAME="sysexts-manager-${SM_VERSION}-${VERSION_ID}-${ARCH}.raw"

# Install the sysexts-manager sysext itself if not present yet.
if [ ! -e "/var/lib/extensions.d/${NAME}" ]; then
    install -d -m 0755 -o 0 -g 0 /var/lib/extensions /var/lib/extensions.d /run/extensions
    tmp="$(mktemp)"
    if ! curl -fsSL "${URL}/${NAME}" -o "${tmp}"; then
        echo "sysext-setup: sysexts-manager download failed (no network?), retrying next boot" >&2
        rm -f "${tmp}"
        exit 0
    fi
    install -m 0644 "${tmp}" "/var/lib/extensions.d/${NAME}"
    rm -f "${tmp}"
    ln -snf "/var/lib/extensions.d/${NAME}" /var/lib/extensions/sysexts-manager.raw
    restorecon -RFv /var/lib/extensions /var/lib/extensions.d /run/extensions 2>/dev/null || true
    # Merge the manager sysext into /usr so its binary becomes available.
    systemctl restart systemd-sysext.service
fi

# sysexts-manager is provided by the just-merged sysext; if it is not on PATH yet, the
# merge has not taken effect -- bail without the marker and retry next boot.
if ! command -v sysexts-manager >/dev/null 2>&1; then
    echo "sysext-setup: sysexts-manager not on PATH yet, retrying next boot" >&2
    exit 0
fi

mkdir -p "$(dirname "${MARKER}")"
touch "${MARKER}"
echo "sysext-setup: sysexts-manager ready (no sysexts installed by default)"
