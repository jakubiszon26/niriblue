#!/usr/bin/bash
#
# niriblue-first-run-keybinds — show niri's native hotkey overlay once, on the
# user's first niri login.
#
# The overlay is rendered by niri from the actual binds (each marked with a
# hotkey-overlay-title), so there is nothing to keep in sync with the config.
# The niri config sets `hotkey-overlay { skip-at-startup }` so it does NOT pop on
# every boot; this script triggers it deliberately, exactly once per user, via a
# marker file.
#
# Launched from niri via spawn-at-startup so it inherits NIRI_SOCKET (a systemd
# user unit would not see it reliably) and only ever runs in the niri session,
# never in the Steam/gamescope session.

set -u

marker="${XDG_STATE_HOME:-$HOME/.local/state}/niriblue/keybinds-shown"
[ -e "$marker" ] && exit 0

# IPC may lag a touch behind process start; wait for niri to answer, then give
# the shell (DMS) a moment so the overlay lands on top of a settled session.
for _ in $(seq 1 40); do
    niri msg version &>/dev/null && break
    sleep 0.25
done
sleep 1

if niri msg action show-hotkey-overlay; then
    mkdir -p "$(dirname "$marker")"
    : > "$marker"
fi
